# ── LLM Provider ─────────────────────────────────────
OPENAI_API_KEY=""

# ── Models ───────────────────────────────────────────
LLM_MODEL="gpt-4o-mini"
EMBEDDING_MODEL="text-embedding-3-small"
DEFAULT_MAX_TOKENS=4096
DEFAULT_TEMPERATURE=0.0

# ── Vector Store ──────────────────────────────────────
VECTOR_STORE_PATH="data/processed/vector_store"
CHROMA_COLLECTION_NAME="prior_auth_policies"

# ── Database ──────────────────────────────────────────
SQLITE_DB_PATH="data/audit.db"

# ── App ───────────────────────────────────────────────
APP_NAME="prior-auth-ai-copilot"
ENV=development
LOG_LEVEL=INFO
